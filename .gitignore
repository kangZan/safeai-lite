*.db
*.db-shm
*.db-wal

# ===== 环境变量 / 密钥 =====
.env
.env.local
.env.*.local

# ===== 系统 / 编辑器 =====
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo

